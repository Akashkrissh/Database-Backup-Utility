# DBVault environment variables
# Copy to .env and fill in values — never commit real credentials

# ── Database ──────────────────────────────────────────────────
DBVAULT_PASSWORD=your_db_password_here

# ── AWS S3 ────────────────────────────────────────────────────
DBVAULT_S3_BUCKET=my-dbvault-bucket
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# ── Google Cloud Storage ──────────────────────────────────────
DBVAULT_GCS_BUCKET=my-gcs-bucket
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Azure Blob Storage ────────────────────────────────────────
DBVAULT_AZURE_CONTAINER=dbvault-container
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# ── Notifications ─────────────────────────────────────────────
DBVAULT_SLACK_WEBHOOK=https://hooks.slack.com/services/T00/B00/XXXX
